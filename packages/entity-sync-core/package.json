{
  "name": "@prometheus-ags/entity-sync-core",
  "version": "0.1.0",
  "description": "PSyncV1 protocol client, reconnect, and JWT management for prometheus-entity-sync",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "license": "MIT",
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "generate-fixtures": "tsx scripts/generate-cross-lang-fixtures.ts",
    "build:bundle": "rollup -c rollup.config.js",
    "size": "pnpm run build:bundle && node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "rollup": "^4.24.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup-plugin-visualizer": "^5.12.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "pg": "^8.13.0"
  }
}
